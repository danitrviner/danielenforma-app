rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Coach permanente — danitrviner@gmail.com
    function isCoach() {
      return request.auth != null && request.auth.token.email == 'danitrviner@gmail.com';
    }

    // El propio atleta leyendo/escribiendo su documento (doc ID = email)
    function isOwnerEmail(email) {
      return request.auth != null && request.auth.token.email == email;
    }

    // El propio usuario leyendo/escribiendo por UID
    function isOwnerUid(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // ── user_profiles (docId = UID) ──────────────────────────────────────────
    // El atleta gestiona su propio perfil, pero los campos que definen su plan
    // de pago (planStartDate/planDurationMonths), su rol y el resumen de setup
    // solo los toca el coach — sin esto, cualquier cliente podía "renovarse"
    // el plan desde la consola del navegador.
    match /user_profiles/{userId} {
      allow read: if isOwnerUid(userId) || isCoach();
      allow create: if isCoach()
                    || (isOwnerUid(userId) && request.resource.data.role == 'client');
      allow update: if isCoach()
                    || (isOwnerUid(userId)
                        && !request.resource.data.diff(resource.data).affectedKeys()
                            .hasAny(['planStartDate', 'planDurationMonths', 'role', 'setupSummary']));
      allow delete: if isCoach();
    }

    // ── checkins (auto-id; campos: userId=UID, email) ────────────────────────
    // El create acepta match por UID o por email: getOrCreateUserProfile puede
    // devolver un perfil con un UID antiguo cuando la misma persona vuelve a
    // registrarse por otro flujo de auth, y el check-in hereda ese userId.
    match /checkins/{docId} {
      allow read: if isCoach()
                  || (request.auth != null && request.auth.uid == resource.data.userId);
      allow create: if isCoach()
                    || (request.auth != null
                        && (request.resource.data.userId == request.auth.uid
                            || request.resource.data.email == request.auth.token.email));
      allow update, delete: if isCoach()
                            || (request.auth != null && request.auth.uid == resource.data.userId);
    }

    // ── exercises (ownerId = UID del coach) ──────────────────────────────────
    match /exercises/{docId} {
      allow read: if request.auth != null;
      allow write: if isCoach();
    }

    // ── exerciseNotes (docId = `${exerciseId}_${athleteId}`; athleteId = EMAIL) ─
    match /exerciseNotes/{docId} {
      allow read: if isCoach()
                  || (request.auth != null && request.auth.token.email == resource.data.athleteId);
      allow write: if isCoach();
    }

    // ── workouts (ownerId = UID del coach) ───────────────────────────────────
    match /workouts/{docId} {
      allow read: if request.auth != null;
      allow write: if isCoach();
    }

    // ── workoutAssignments (athleteId = UID) ─────────────────────────────────
    match /workoutAssignments/{docId} {
      allow read: if isCoach()
                  || (request.auth != null && request.auth.uid == resource.data.athleteId);
      allow write: if isCoach();
    }

    // ── workoutLogs (athleteId = EMAIL) ──────────────────────────────────────
    match /workoutLogs/{docId} {
      allow read: if isCoach()
                  || (request.auth != null && request.auth.token.email == resource.data.athleteId);
      allow create: if isCoach()
                    || (request.auth != null
                        && request.resource.data.athleteId == request.auth.token.email);
      allow update, delete: if isCoach()
                            || (request.auth != null && request.auth.token.email == resource.data.athleteId);
    }

    // ── foodItems (sin propietario, compartidos) ─────────────────────────────
    match /foodItems/{docId} {
      allow read: if request.auth != null;
      allow write: if isCoach();
    }

    // ── diets (athleteId = EMAIL) ────────────────────────────────────────────
    match /diets/{docId} {
      allow read: if isCoach()
                  || (request.auth != null && request.auth.token.email == resource.data.athleteId);
      // Self-managed diets ("Mis Dietas") are the athlete's own — they may create
      // their own, and update/delete only ones already flagged selfManaged.
      // Coach-assigned diets (selfManaged absent/false) remain read-only for athletes.
      allow create: if isCoach()
                    || (request.auth != null
                        && request.auth.token.email == request.resource.data.athleteId
                        && request.resource.data.selfManaged == true);
      allow update, delete: if isCoach()
                            || (request.auth != null
                                && request.auth.token.email == resource.data.athleteId
                                && resource.data.selfManaged == true);
    }

    // ── athleteDietConfigs (docId = email) ───────────────────────────────────
    match /athleteDietConfigs/{email} {
      allow read, write: if isCoach() || isOwnerEmail(email);
    }

    // ── athleteNutritionConfigs (docId = email) ──────────────────────────────
    match /athleteNutritionConfigs/{email} {
      allow read, write: if isCoach() || isOwnerEmail(email);
    }

    // ── mesocycles (athleteId = EMAIL) ───────────────────────────────────────
    match /mesocycles/{docId} {
      allow read: if isCoach()
                  || (request.auth != null && request.auth.token.email == resource.data.athleteId);
      allow write: if isCoach();
    }

    // ── mesocycleTemplates (ownerId = UID del coach) ─────────────────────────
    match /mesocycleTemplates/{docId} {
      allow read: if request.auth != null;
      allow write: if isCoach();
    }

    // ── recipes (ownerId = UID | 'indya') ────────────────────────────────────
    match /recipes/{docId} {
      allow read: if request.auth != null;
      allow create: if isCoach();
      allow update, delete: if isCoach() || isOwnerUid(resource.data.ownerId);
    }

    // ── recipeFavorites (docId = email) ──────────────────────────────────────
    match /recipeFavorites/{email} {
      allow read, write: if isCoach() || isOwnerEmail(email);
    }

    // ── progressPhotos (athleteId = EMAIL) ───────────────────────────────────
    match /progressPhotos/{docId} {
      allow read: if isCoach()
                  || (request.auth != null && request.auth.token.email == resource.data.athleteId);
      allow create: if request.auth != null
                    && request.resource.data.athleteId == request.auth.token.email;
      allow update, delete: if isCoach()
                            || (request.auth != null && request.auth.token.email == resource.data.athleteId);
    }

    // ── bodyweightLogs (athleteId = EMAIL) ───────────────────────────────────
    match /bodyweightLogs/{docId} {
      allow read: if isCoach()
                  || (request.auth != null && request.auth.token.email == resource.data.athleteId);
      allow create: if request.auth != null
                    && request.resource.data.athleteId == request.auth.token.email;
      allow update, delete: if isCoach()
                            || (request.auth != null && request.auth.token.email == resource.data.athleteId);
    }

    // ── stepLogs (athleteId = EMAIL) ─────────────────────────────────────────
    match /stepLogs/{docId} {
      allow read: if isCoach()
                  || (request.auth != null && request.auth.token.email == resource.data.athleteId);
      allow create: if request.auth != null
                    && request.resource.data.athleteId == request.auth.token.email;
      allow update, delete: if isCoach()
                            || (request.auth != null && request.auth.token.email == resource.data.athleteId);
    }

    // ── dietCompletionLogs (docId = `${athleteId}_${date}`; athleteId = EMAIL) ─
    match /dietCompletionLogs/{docId} {
      allow read: if isCoach()
                  || (request.auth != null && request.auth.token.email == resource.data.athleteId);
      allow create: if request.auth != null
                    && request.resource.data.athleteId == request.auth.token.email;
      allow update, delete: if isCoach()
                            || (request.auth != null && request.auth.token.email == resource.data.athleteId);
    }

    // ── questionnaires (ownerId = UID del coach) ─────────────────────────────
    match /questionnaires/{docId} {
      allow read: if request.auth != null;
      allow write: if isCoach();
    }

    // ── questionnaireAssignments (athleteId = EMAIL) ─────────────────────────
    match /questionnaireAssignments/{docId} {
      allow read: if isCoach()
                  || (request.auth != null && request.auth.token.email == resource.data.athleteId);
      allow write: if isCoach();
    }

    // ── photoAssignments (athleteId = EMAIL) ─────────────────────────────────
    match /photoAssignments/{docId} {
      allow read: if isCoach()
                  || (request.auth != null && request.auth.token.email == resource.data.athleteId);
      allow write: if isCoach();
    }

    // ── questionnaireResponses (athleteId = EMAIL) ───────────────────────────
    match /questionnaireResponses/{docId} {
      allow read: if isCoach()
                  || (request.auth != null && request.auth.token.email == resource.data.athleteId);
      allow create: if isCoach()
                    || (request.auth != null
                        && request.resource.data.athleteId == request.auth.token.email);
      allow update, delete: if isCoach()
                            || (request.auth != null && request.auth.token.email == resource.data.athleteId);
    }

    // ── onboarding (docId = email) ───────────────────────────────────────────
    match /onboarding/{email} {
      allow read, write: if isCoach() || isOwnerEmail(email);
    }

    // ── nutritionPrograms (docId = email) ────────────────────────────────────
    match /nutritionPrograms/{email} {
      allow read, write: if isCoach() || isOwnerEmail(email);
    }

    // ── roadmaps (docId = email) ─────────────────────────────────────────────
    match /roadmaps/{email} {
      allow read, write: if isCoach() || isOwnerEmail(email);
    }

    // ── weeklyChallenges (docId = `${email}_${isoWeek}`; athleteId = EMAIL) ──
    // El atleta puede crear su propio reto (el auto-fallback semanal corre bajo
    // su sesión) y actualizar el progreso/estado; el coach puede todo.
    // `resource == null` cubre el primer `get` de la semana, antes de que el
    // doc exista (generate-on-read): no hay dato que proteger todavía, así que
    // se permite leer "no existe" en vez de denegar por falta de resource.data.
    match /weeklyChallenges/{docId} {
      allow read: if isCoach()
                  || (request.auth != null
                      && (resource == null || request.auth.token.email == resource.data.athleteId));
      allow create: if isCoach()
                    || (request.auth != null
                        && request.resource.data.athleteId == request.auth.token.email);
      allow update, delete: if isCoach()
                            || (request.auth != null && request.auth.token.email == resource.data.athleteId);
    }

    // ── challengeTemplates (biblioteca de retos; ownerId = UID del coach) ────
    match /challengeTemplates/{docId} {
      allow read: if request.auth != null;
      allow write: if isCoach();
    }

    // ── invites (docId = email) — coach invites a new client by email ────────
    // Update is also allowed to the invited email itself: markInviteJoined()
    // runs under the newly-created client's own auth session right after they
    // sign in via the invite link, not the coach's.
    match /invites/{email} {
      allow read: if isCoach();
      allow create: if isCoach();
      allow update: if isCoach() || isOwnerEmail(email);
      allow delete: if isCoach();
    }

    // ── notifications (recipientEmail) ───────────────────────────────────────
    // Create checks request.resource (on create `resource` doesn't exist yet, so
    // reading resource.data would error out and deny every athlete-side create —
    // that silently dropped all athlete→coach notifications). Athletes may only
    // address notifications to themselves or to the coach.
    match /notifications/{docId} {
      allow read: if isCoach()
                  || (request.auth != null && request.auth.token.email == resource.data.recipientEmail);
      allow create: if isCoach()
                    || (request.auth != null
                        && (request.resource.data.recipientEmail == request.auth.token.email
                            || request.resource.data.recipientEmail == 'danitrviner@gmail.com'));
      allow update, delete: if isCoach()
                            || (request.auth != null && request.auth.token.email == resource.data.recipientEmail);
    }

    // ── tasks (athleteId = EMAIL) ────────────────────────────────────────────
    match /tasks/{docId} {
      allow read: if isCoach()
                  || (request.auth != null && request.auth.token.email == resource.data.athleteId);
      allow create: if isCoach();
      allow update, delete: if isCoach()
                            || (request.auth != null && request.auth.token.email == resource.data.athleteId);
    }

    // ── resources (coachId = UID del coach; lectura para cualquier atleta autenticado) ──
    match /resources/{docId} {
      allow read: if request.auth != null;
      allow write: if isCoach();
    }

    // ── onboardingTemplates (docId = email del coach) ────────────────────────
    // Sin esta regla la colección caía en el default-deny: ni el propio coach
    // podía leer su plantilla y la app vivía de la copia en localStorage.
    // Lectura para cualquier autenticado (la plantilla no contiene datos
    // personales); escritura solo coach.
    match /onboardingTemplates/{coachEmail} {
      allow read: if request.auth != null;
      allow write: if isCoach();
    }

    // ── coachNotes (private to-do list — never visible to athletes) ──────────
    match /coachNotes/{docId} {
      allow read, write: if isCoach();
    }

    // ── coachClientTasks (Setup panel checklist — private to the coach) ──────
    match /coachClientTasks/{docId} {
      allow read, write: if isCoach();
    }

    // ── aiChats (conversaciones del asistente IA — privadas del coach) ───────
    match /aiChats/{docId} {
      allow read, write: if isCoach();
    }

    // ── aiProposals (propuestas de la IA pendientes de aprobación) ───────────
    // Nunca visibles para el atleta: la entidad real solo se crea cuando el
    // coach aprueba desde la UI.
    match /aiProposals/{docId} {
      allow read, write: if isCoach();
    }

    // ── aiAuditLog (escrito por el proxy de Vercel con admin SDK) ────────────
    // El cliente solo puede leer (coach); la escritura va por firebase-admin,
    // que se salta las reglas — denegar write aquí evita registros falsificados.
    match /aiAuditLog/{docId} {
      allow read: if isCoach();
      allow write: if false;
    }

    // ── knowledgeBase (bóveda de metodología del coach — solo-coach) ─────────
    // Apuntes internos de cursos: nunca visibles para el atleta. La IA los
    // consulta desde la sesión autenticada del coach.
    match /knowledgeBase/{docId} {
      allow read, write: if isCoach();
    }

    // ── coachSettings (instrucciones fijas del coach para la IA — solo-coach) ─
    match /coachSettings/{docId} {
      allow read, write: if isCoach();
    }

    // ── athleteStatus (nota de estado por atleta en el ClientHub — solo-coach) ─
    match /athleteStatus/{docId} {
      allow read, write: if isCoach();
    }

    // ── coachReports (athleteId = EMAIL) ─────────────────────────────────────
    // Coach reads/writes everything; the athlete may only read their own SENT
    // reports (drafts stay hidden), so athlete queries must filter status=='sent'.
    match /coachReports/{docId} {
      allow read: if isCoach()
                  || (request.auth != null
                      && request.auth.token.email == resource.data.athleteId
                      && resource.data.status == 'sent');
      allow write: if isCoach();
    }

  }
}
